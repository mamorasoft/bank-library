{
  "name": "format-rupiah-vue",
  "version": "1.0.0",
  "description": "Vue 3 helper library to format nominal values to Indonesian Rupiah and parse formatted inputs back to numbers.",
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "vue",
    "vue3",
    "rupiah",
    "currency",
    "indonesia",
    "format",
    "parser",
    "directive"
  ],
  "author": "Mamorasoft",
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "jsdom": "^29.1.1",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0",
    "vitest": "^1.0.0",
    "vue": "^3.0.0"
  }
}
